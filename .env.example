# ============================================
# Base4Empresas - Variables de Entorno
# ============================================
# Copia este archivo a .env y configura los valores según tu entorno

# ============================================
# APLICACIÓN
# ============================================

# Modo de la aplicación (development, staging, production)
NODE_ENV=development

# Puerto del servidor de desarrollo
NG_APP_PORT=4200

# ============================================
# API BACKEND
# ============================================

# URL base del API backend
NG_APP_API_URL=http://localhost:3000

# Tiempo de timeout para las peticiones (en milisegundos)
NG_APP_API_TIMEOUT=30000

# ============================================
# SEGURIDAD
# ============================================

# Token JWT (si aplica)
NG_APP_AUTH_TOKEN=

# CORS - Dominios permitidos (separados por comas)
NG_APP_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ============================================
# LOGGING
# ============================================

# Nivel de log (debug, info, warning, error)
NG_APP_LOG_LEVEL=info

# ============================================
# CONFIGURACIÓN SSR (Server-Side Rendering)
# ============================================

# Puerto del servidor SSR
SSR_PORT=4000

# ============================================
# MODULO ESPECIFICO - INVENTARIO
# ============================================

# Moneda por defecto para el sistema
NG_APP_DEFAULT_CURRENCY=USD

# Fecha de inicio del sistema
NG_APP_START_DATE=2026-01-01

# ============================================
# INTEGRACIONES EXTERNAS (Opcional)
# ============================================

# Google Analytics
NG_APP_GA_ID=

# Sentry (Error tracking)
NG_APP_SENTRY_DSN=

# Firebase (si aplica)
NG_APP_FIREBASE_API_KEY=
NG_APP_FIREBASE_AUTH_DOMAIN=
NG_APP_FIREBASE_PROJECT_ID=
